{com}. 
. local still_nonstat = 0
{txt}
{com}. foreach v of global finalvars {c -(}
{txt}  2{com}.     qui pperron `v', lags(8) trend
{txt}  3{com}.     local pv = r(p)
{txt}  4{com}.     if `pv' < 0.05 {c -(}
{txt}  5{com}.         di as result "  %-24s p = " %5.3f `pv' "  I(0) ✓"
{txt}  6{com}.     {c )-}
{txt}  7{com}.     else {c -(}
{txt}  8{com}.         di as error  "  %-24s p = " %5.3f `pv' "  ALERTA: sigue no-estacionaria"
{txt}  9{com}.         local still_nonstat = 1
{txt} 10{com}.     {c )-}
{txt} 11{com}. {c )-}
{err}  %-24s p = 0.231  ALERTA: sigue no-estacionaria
  %-24s p = 0.104  ALERTA: sigue no-estacionaria
{res}  %-24s p = 0.000  I(0) ✓
{err}  %-24s p = 0.973  ALERTA: sigue no-estacionaria
{txt}
{com}. 
. if `still_nonstat' {c -(}
.     di as error _n "  AVISO: variable(s) no-estacionarias → reportado a Claude."
{res}
{err}  AVISO: variable(s) no-estacionarias → reportado a Claude.
{com}. {c )-}
{txt}
{com}. 
