. /* ════════════════════════════════════════════════════════════
>    SECCIÓN 10  GENERAR var_simple.do
>    Estilo codigos.do: lineal, sin automatización, ~40 líneas.
>    ════════════════════════════════════════════════════════════ */
. 
. di _newline(2) as result ///
>   "══════════════════════════════════════════" _n ///
>   "  SECCIÓN 10: GENERANDO var_simple.do"    _n ///
>   "══════════════════════════════════════════"
{res}

══════════════════════════════════════════
  SECCIÓN 10: GENERANDO var_simple.do
══════════════════════════════════════════
{txt}
{com}. 
. file open fsimple using `"$scrpdir/var_simple.do"', write replace text
{txt}{p 0 4 2}
(file {bf}
output/run_20260520/scripts/var_simple.do{rm}
not found)
{p_end}

{com}. 
. file write fsimple "/*=============================================" _n
{txt}
{com}. file write fsimple "  VAR Simple"                                     _n
{txt}
{com}. file write fsimple "  Especificación: VAR($p_use) | $inicio–$fin"    _n
{txt}
{com}. file write fsimple "  Cholesky: $chol_order"                         _n
{txt}
{com}. file write fsimple "  Generado por: var_completo.do"                 _n
{txt}
{com}. file write fsimple "=============================================*/"  _n _n
{txt}
{com}. 
. file write fsimple "*** Configurar serie de tiempo ***"               _n
{txt}
{com}. file write fsimple "gen time = tm($startdate) + _n - 1"              _n
{txt}
{com}. file write fsimple "format time %tm"                                  _n
{txt}
{com}. file write fsimple "tsset time, monthly"                              _n _n
{txt}
{com}. 
. file write fsimple "*** Prueba de estacionariedad (niveles) ***"     _n
{txt}
{com}. foreach v of global rawvars {c -(}
{txt}  2{com}.     file write fsimple "pperron `v'" _n
{txt}  3{com}. {c )-}
{txt}
{com}. file write fsimple _n
{txt}
{com}. 
. file write fsimple "*** Crear variables ***"                          _n
{txt}
{com}. foreach v of global rawvars {c -(}
{txt}  2{com}.     local tr "${c -(}trans_`v'{c )-}"
{txt}  3{com}.     if "`tr'" == "level"   file write fsimple "* `v': se usa en niveles" _n
{txt}  4{com}.     if "`tr'" == "log"     file write fsimple "gen l_`v' = log(`v')" _n
{txt}  5{com}.     if "`tr'" == "diff"    file write fsimple "gen d_`v' = D.`v'" _n
{txt}  6{com}.     if "`tr'" == "diff3"   file write fsimple "gen d3_`v' = `v' - L3.`v'" _n
{txt}  7{com}.     if "`tr'" == "logdiff" file write fsimple "gen dl_`v' = D.log(`v')" _n
{txt}  8{com}.     if "`tr'" == "pct"     file write fsimple "gen pct_`v' = (`v'/L.`v'-1)*100" _n
{txt}  9{com}.     if "`tr'" == "pct3"    file write fsimple "gen pct3_`v' = (`v'/L3.`v'-1)*100" _n
{txt} 10{com}. {c )-}
{txt}
{com}. file write fsimple _n
{txt}
{com}. 
. file write fsimple "*** Prueba de estacionariedad (vars. transformadas) ***" _n
{txt}
{com}. foreach v of global finalvars {c -(}
{txt}  2{com}.     file write fsimple "pperron `v'" _n
{txt}  3{com}. {c )-}
{txt}
{com}. file write fsimple _n
{txt}
{com}. 
. file write fsimple "*** Selección de rezagos ***"                     _n
{txt}
{com}. if "$exogenas" != "" {c -(}
.     file write fsimple "varsoc $chol_order, maxlag($p_max) exog($exogenas)" _n _n
. {c )-}
{txt}
{com}. else {c -(}
.     file write fsimple "varsoc $chol_order, maxlag($p_max)" _n _n
. {c )-}
{txt}
{com}. 
. file write fsimple "*** Estimación VAR ***"                           _n
{txt}
{com}. if "$exogenas" != "" {c -(}
.     file write fsimple "var $chol_order, lags(1/$p_use) exog($exogenas)" _n _n
. {c )-}
{txt}
{com}. else {c -(}
.     file write fsimple "var $chol_order, lags(1/$p_use)" _n _n
. {c )-}
{txt}
{com}. 
. file write fsimple "*** Diagnósticos ***"                             _n
{txt}
{com}. file write fsimple "varwle"                                           _n
{txt}
{com}. file write fsimple "varlmar, mlag(6)"                                 _n
{txt}
{com}. file write fsimple "varstable, graph dlabel"                          _n
{txt}
{com}. file write fsimple "vargranger"                                       _n _n
{txt}
{com}. 
. file write fsimple "*** IRF ***"                                      _n
{txt}
{com}. file write fsimple `"irf create irf_run, step($irf_step) set("irf_run") replace"' _n
{txt}
{com}. foreach imp of local vars_list {c -(}
{txt}  2{com}.     foreach resp of local vars_list {c -(}
{txt}  3{com}.         file write fsimple ///
>             "irf graph oirf, impulse(`imp') response(`resp') irf(irf_run)" _n
{txt}  4{com}.     {c )-}
{txt}  5{com}. {c )-}
{txt}
{com}. file write fsimple _n
{txt}
{com}. 
. file write fsimple "*** Descomposición de varianza ***"               _n
{txt}
{com}. file write fsimple "irf table fevd, noci"                             _n
{txt}
{com}. 
. file close fsimple
{txt}
{com}. di as result "  → var_simple.do generado"
{res}  → var_simple.do generado
{txt}
{com}. 
. 
. /* ════════════════════════════════════════════════════════════
>    SECCIÓN 11  CERRAR, COPIAR Y RESUMEN FINAL
>    ════════════════════════════════════════════════════════════ */
. 
. cap copy "var_auto.do" `"$scrpdir/var_completo.do"', replace
{txt}
{com}. 
. log close varlog
      {txt}name:  {res}varlog
       {txt}log:  {res}C:\Users\51950\Documents\Claude_Jorge_PROYECTOS\Project_VAR\output/run_20260520/log_var.smcl
  {txt}log type:  {res}smcl
 {txt}closed on:  {res}20 May 2026, 18:56:02
{txt}{.-}
{smcl}
{txt}{sf}{ul off}