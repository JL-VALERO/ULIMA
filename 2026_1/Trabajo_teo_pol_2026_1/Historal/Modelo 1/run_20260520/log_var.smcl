. /* ════════════════════════════════════════════════════════════
>    SECCIÓN 3  APLICAR TRANSFORMACIONES
>    ════════════════════════════════════════════════════════════ */
. 
. di _newline(2) as result ///
>   "══════════════════════════════════════════" _n ///
>   "  SECCIÓN 3: TRANSFORMACIONES"            _n ///
>   "══════════════════════════════════════════"
{res}

══════════════════════════════════════════
  SECCIÓN 3: TRANSFORMACIONES
══════════════════════════════════════════
{txt}
{com}. 
. global finalvars ""
{txt}
{com}. 
. foreach v of global rawvars {c -(}
{txt}  2{com}.     local tr "${c -(}trans_`v'{c )-}"
{txt}  3{com}. 
.     if "`tr'" == "level" {c -(}
{txt}  4{com}.         global finalvars "$finalvars `v'"
{txt}  5{com}.         global fname_`v' "`v'"
{txt}  6{com}.         di as text "  `v'  →  nivel  [`v']"
{txt}  7{com}.     {c )-}
{txt}  8{com}.     else if "`tr'" == "log" {c -(}
{txt}  9{com}.         cap drop l_`v'
{txt} 10{com}.         gen l_`v' = log(`v')
{txt} 11{com}.         label var l_`v' "log(`v')"
{txt} 12{com}.         global finalvars "$finalvars l_`v'"
{txt} 13{com}.         global fname_`v' "l_`v'"
{txt} 14{com}.         di as text "  `v'  →  log(`v')  [l_`v']"
{txt} 15{com}.     {c )-}
{txt} 16{com}.     else if "`tr'" == "diff" {c -(}
{txt} 17{com}.         cap drop d_`v'
{txt} 18{com}.         gen d_`v' = D.`v'
{txt} 19{com}.         label var d_`v' "D.`v'"
{txt} 20{com}.         global finalvars "$finalvars d_`v'"
{txt} 21{com}.         global fname_`v' "d_`v'"
{txt} 22{com}.         di as text "  `v'  →  D.`v'  [d_`v']"
{txt} 23{com}.     {c )-}
{txt} 24{com}.     else if "`tr'" == "diff3" {c -(}
{txt} 25{com}.         cap drop d3_`v'
{txt} 26{com}.         gen d3_`v' = `v' - L3.`v'
{txt} 27{com}.         label var d3_`v' "D3.`v' (var. trim.)"
{txt} 28{com}.         global finalvars "$finalvars d3_`v'"
{txt} 29{com}.         global fname_`v' "d3_`v'"
{txt} 30{com}.         di as text "  `v'  →  `v' - L3.`v'  [d3_`v']"
{txt} 31{com}.     {c )-}
{txt} 32{com}.     else if "`tr'" == "logdiff" {c -(}
{txt} 33{com}.         cap drop dl_`v'
{txt} 34{com}.         gen dl_`v' = D.log(`v')
{txt} 35{com}.         label var dl_`v' "D.log(`v')"
{txt} 36{com}.         global finalvars "$finalvars dl_`v'"
{txt} 37{com}.         global fname_`v' "dl_`v'"
{txt} 38{com}.         di as text "  `v'  →  D.log(`v')  [dl_`v']"
{txt} 39{com}.     {c )-}
{txt} 40{com}.     else if "`tr'" == "pct" {c -(}
{txt} 41{com}.         cap drop pct_`v'
{txt} 42{com}.         gen pct_`v' = (`v' / L.`v' - 1) * 100
{txt} 43{com}.         label var pct_`v' "Var.% `v'"
{txt} 44{com}.         global finalvars "$finalvars pct_`v'"
{txt} 45{com}.         global fname_`v' "pct_`v'"
{txt} 46{com}.         di as text "  `v'  →  var.% mensual  [pct_`v']"
{txt} 47{com}.     {c )-}
{txt} 48{com}.     else if "`tr'" == "pct3" {c -(}
{txt} 49{com}.         cap drop pct3_`v'
{txt} 50{com}.         gen pct3_`v' = (`v' / L3.`v' - 1) * 100
{txt} 51{com}.         label var pct3_`v' "Var.% trim. `v'"
{txt} 52{com}.         global finalvars "$finalvars pct3_`v'"
{txt} 53{com}.         global fname_`v' "pct3_`v'"
{txt} 54{com}.         di as text "  `v'  →  (`v'/L3.`v'-1)*100  [pct3_`v']"
{txt} 55{com}.     {c )-}
{txt} 56{com}.     else {c -(}
{txt} 57{com}.         di as error "  ERROR: transformación '`tr'' desconocida para `v'."
{txt} 58{com}.         di as error "  Opciones: level | log | diff | diff3 | logdiff | pct | pct3"
{txt} 59{com}.         log close varlog
{txt} 60{com}.         exit 1
{txt} 61{com}.     {c )-}
{txt} 62{com}. {c )-}
{txt}  tasa_ref  →  nivel  [tasa_ref]
  tamn  →  nivel  [tamn]
(1 missing value generated)
  ipc  →  var.% mensual  [pct_ipc]
  tc  →  nivel  [tc]

{com}. 
. di as result _n "  Variables finales: $finalvars"
{res}
  Variables finales:  tasa_ref tamn pct_ipc tc
{txt}
{com}. 
. 
