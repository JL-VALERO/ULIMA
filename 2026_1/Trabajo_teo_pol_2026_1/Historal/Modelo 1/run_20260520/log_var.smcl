>    ════════════════════════════════════════════════════════════ */
. 
. di _newline(2) as result ///
>   "══════════════════════════════════════════" _n ///
>   "  SECCIÓN 1: IMPORTAR Y DIAGNOSTICAR"     _n ///
>   "══════════════════════════════════════════"
{res}

══════════════════════════════════════════
  SECCIÓN 1: IMPORTAR Y DIAGNOSTICAR
══════════════════════════════════════════
{txt}
{com}. 
. import excel using "$datafile", ///
>     sheet("$hoja") cellrange("$cellrange") firstrow clear
{res}{text}(5 vars, 264 obs)

{com}. 
. * ── Configurar serie de tiempo ───────────────────────────────
. if "$datemode" == "manual" {c -(}
.     gen __t = tm($startdate) + _n - 1
.     format __t %tm
.     tsset __t, monthly
.     keep if __t >= tm($inicio) & __t <= tm($fin)
. {c )-}
{txt}
{com}. else {c -(}
.     gen __t = mofd($datevar)
.     format __t %tm
.     tsset __t, monthly
{res}
{p 0 15 2}{txt:Time variable: }{res:__t}{txt:, }{res:{bind:2004m1}}{txt: to }{res:{bind:2025m12}}{p_end}
{txt}{col 9}Delta: {res}1 month
{com}.     keep if __t >= tm($inicio) & __t <= tm($fin)
{txt}(48 observations deleted)
{com}. {c )-}
{txt}
{com}. 
. qui count
{txt}
{com}. local total_obs = r(N)
{txt}
{com}. di as result "  Observaciones: `total_obs'  |  Período: $inicio – $fin"
{res}  Observaciones: 216  |  Período: 2004m1 – 2021m12
{txt}
{com}. 
. * ── Diagnóstico de calidad de datos ─────────────────────────
. di _newline as text "── Diagnóstico de datos ──"
{res}
{txt}── Diagnóstico de datos ──

