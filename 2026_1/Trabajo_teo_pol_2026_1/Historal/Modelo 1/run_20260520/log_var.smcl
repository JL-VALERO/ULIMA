{res}{txt}  ─────────────  ──────   ──────   ──────   ──────   ─────────────

{com}. 
. foreach v of global rawvars {c -(}
{txt}  2{com}.     qui dfuller `v', lags(4) trend
{txt}  3{com}.     local t_adf = r(Zt)
{txt}  4{com}.     local p_adf = r(p)
{txt}  5{com}.     qui pperron `v', lags(8) trend
{txt}  6{com}.     local t_pp  = r(Zt)
{txt}  7{com}.     local p_pp  = r(p)
{txt}  8{com}. 
.     di as text "  " %-14s "`v'" ///
>        %7.3f `t_adf' "  " %6.3f `p_adf' "  " ///
>        %7.3f `t_pp'  "  " %6.3f `p_pp'  "  " ///
>        "→ ${c -(}trans_`v'{c )-}"
{txt}  9{com}. {c )-}
