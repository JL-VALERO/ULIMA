{com}. di as text "  ──────────────────────────────────────────────────────────────────"
{res}{txt}  ──────────────────────────────────────────────────────────────────

{com}. 
. local any_miss_alert = 0
{txt}
{com}. 
. foreach v of global rawvars {c -(}
{txt}  2{com}.     cap confirm variable `v'
{txt}  3{com}.     if _rc != 0 {c -(}
{txt}  4{com}.         di as error "  ERROR: la variable '`v'' no existe en el Excel."
{txt}  5{com}.         di as error "  Variables disponibles:"
{txt}  6{com}.         describe, simple
{txt}  7{com}.         log close varlog
{txt}  8{com}.         exit 1
{txt}  9{com}.     {c )-}
{txt} 10{com}. 
.     qui count if missing(`v')
{txt} 11{com}.     local nmiss   = r(N)
{txt} 12{com}.     local nvalid  = `total_obs' - `nmiss'
{txt} 13{com}.     local pctmiss = round(`nmiss' / `total_obs' * 100, 0.1)
{txt} 14{com}.     qui sum `v'
{txt} 15{com}.     local vmin = r(min)
{txt} 16{com}.     local vmax = r(max)
{txt} 17{com}. 
.     if `pctmiss' > 20 {c -(}
{txt} 18{com}.         di as error "  " %-18s "`v'" %6.0f `nvalid' "      " %5.0f `nmiss' ///
>             "    " %5.1f `pctmiss' "%   " %10.3g `vmin' "  " %10.3g `vmax' ///
>             "  ← ALERTA >20%"
{txt} 19{com}.         local any_miss_alert = 1
{txt} 20{com}.     {c )-}
{txt} 21{com}.     else if `pctmiss' > 0 {c -(}
{txt} 22{com}.         di as text "  " %-18s "`v'" %6.0f `nvalid' "      " %5.0f `nmiss' ///
>             "    " %5.1f `pctmiss' "%   " %10.3g `vmin' "  " %10.3g `vmax' ///
>             "  ← missings"
{txt} 23{com}.     {c )-}
{txt} 24{com}.     else {c -(}
{txt} 25{com}.         di as result "  " %-18s "`v'" %6.0f `nvalid' "      " %5.0f `nmiss' ///
>             "    " %5.1f `pctmiss' "%   " %10.3g `vmin' "  " %10.3g `vmax'
{txt} 26{com}.     {c )-}
{txt} 27{com}. {c )-}
