. /* ----------------------------------------------------------
>    4. PRUEBAS DE RAIZ UNITARIA
>    H0: tiene raiz unitaria (I(1))
>    tasa_ref, tamn, tc -> se espera I(1)
>    inflacion          -> se espera I(0)
> ---------------------------------------------------------- */
. 
. display _newline "=== PRUEBAS DE RAIZ UNITARIA ==="

=== PRUEBAS DE RAIZ UNITARIA ===

. 
. * Variables en niveles
. foreach v in tasa_ref tamn ltc {
  2.     display _newline "--- ADF: `v' (niveles, con constante) ---"
  3.     dfuller `v', lags(12)
  4.     display _newline "--- ADF: `v' (niveles, con tendencia) ---"
  5.     dfuller `v', lags(12) trend
  6.     display _newline "--- PP: `v' (niveles) ---"
  7.     pperron `v', lags(6)
  8. }

